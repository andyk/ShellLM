#!/usr/bin/env bash
set -euo pipefail

# context — Policy layer for shellm trajectory rendering.
# Reads trajectory.jsonl (and spilled blobs) directly from disk and emits
# a model-facing context to stdout. A filter from the full lossless trajectory
# to a bounded view.

# ---------------------------------------------------------------------------
# Defaults
# ---------------------------------------------------------------------------

TRAJ_FILE="trajectory.jsonl"
BLOB_DIR="trajectory_blobs"

CTX_HEAD="${CTX_HEAD:-1}"
CTX_TAIL="${CTX_TAIL:-50}"
CTX_PROMPT_LIMIT="${SHELLM_STDOUT_PROMPT_LIMIT:-2048}"
CTX_MAX_BYTES=""
CTX_FIELDS=""  # empty = all
CTX_ELISION_STYLE="count"  # none|count|digest
CTX_PINS=()

die() { printf 'context: error: %s\n' "$*" >&2; exit 1; }
usage() {
    cat <<'EOF'
Usage: context <run_dir> [options]

Reads trajectory.jsonl and emits a model-facing context to stdout.

Step selection:
  --head N              Keep first N steps. Default: 1.
  --tail N              Keep last N steps. Default: 50.
  --pin <step_id>       Always include this step. Repeatable.

Per-step content:
  --fields LIST         Comma-separated subset of {thought,cmd,stdout,stderr,exit,ts}.
                        Default: all.
  --prompt-limit BYTES  Per-step truncation for stdout/stderr. Default: 2048.

Elision:
  --elision-style S     none|count|digest. Default: count.

Budget:
  --max-bytes BYTES     Cap total output. Default: unset.

EOF
    exit "${1:-0}"
}

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------

RUN_DIR=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --head)           CTX_HEAD="${2:?--head requires N}"; shift 2 ;;
        --tail)           CTX_TAIL="${2:?--tail requires N}"; shift 2 ;;
        --pin)            CTX_PINS+=("${2:?--pin requires step_id}"); shift 2 ;;
        --fields)         CTX_FIELDS="${2:?--fields requires LIST}"; shift 2 ;;
        --prompt-limit)   CTX_PROMPT_LIMIT="${2:?--prompt-limit requires BYTES}"; shift 2 ;;
        --elision-style)  CTX_ELISION_STYLE="${2:?--elision-style requires a value}"; shift 2 ;;
        --max-bytes)      CTX_MAX_BYTES="${2:?--max-bytes requires BYTES}"; shift 2 ;;
        -h|--help)        usage 0 ;;
        -*)               die "unknown option: $1" ;;
        *)
            if [[ -z "$RUN_DIR" ]]; then
                RUN_DIR="$1"
            else
                die "unexpected argument: $1"
            fi
            shift
            ;;
    esac
done

[[ -n "$RUN_DIR" ]] || die "run_dir is required"

SHELLM_DIR="$RUN_DIR/.shellm"
TRAJ_PATH="$SHELLM_DIR/$TRAJ_FILE"

[[ -f "$TRAJ_PATH" ]] || die "trajectory not found: $TRAJ_PATH"

# Parse fields into a delimited string for lookup (bash 3.2 compatible).
_FIELD_SET=""
if [[ -n "$CTX_FIELDS" ]]; then
    IFS=',' read -ra _flds <<< "$CTX_FIELDS"
    for _f in "${_flds[@]}"; do
        _FIELD_SET="${_FIELD_SET}|${_f}|"
    done
else
    for _f in thought cmd stdout stderr exit ts; do
        _FIELD_SET="${_FIELD_SET}|${_f}|"
    done
fi

field_enabled() {
    [[ "$_FIELD_SET" == *"|$1|"* ]]
}

# Build pin set as delimited string for lookup.
_PIN_SET=""
for _p in "${CTX_PINS[@]+"${CTX_PINS[@]}"}"; do
    _PIN_SET="${_PIN_SET}|${_p}|"
done

pin_match() {
    [[ "$_PIN_SET" == *"|$1|"* ]]
}

# ---------------------------------------------------------------------------
# Phase 1: Load trajectory rows
# ---------------------------------------------------------------------------

# Read all rows that have a step_id.
ALL_ROWS=()
ALL_IDS=()
while IFS= read -r line; do
    local_id=$(printf '%s' "$line" | jq -r '.step_id // empty' 2>/dev/null)
    [[ -n "$local_id" ]] || continue
    ALL_ROWS+=("$line")
    ALL_IDS+=("$local_id")
done < "$TRAJ_PATH"

TOTAL=${#ALL_ROWS[@]}

# ---------------------------------------------------------------------------
# Phase 2: Step selection
# ---------------------------------------------------------------------------

# Determine which indices survive: head, tail, and pinned.
# Use a delimited string for bash 3.2 compat (no associative arrays).
_SELECTED=""

# Head: first N steps.
for ((i=0; i<TOTAL && i<CTX_HEAD; i++)); do
    _SELECTED="${_SELECTED}|${i}|"
done

# Tail: last N steps.
tail_start=$((TOTAL - CTX_TAIL))
[[ "$tail_start" -lt 0 ]] && tail_start=0
for ((i=tail_start; i<TOTAL; i++)); do
    _SELECTED="${_SELECTED}|${i}|"
done

# Pins: find by step_id.
for ((i=0; i<TOTAL; i++)); do
    if pin_match "${ALL_IDS[$i]}"; then
        _SELECTED="${_SELECTED}|${i}|"
    fi
done

is_selected() {
    [[ "$_SELECTED" == *"|$1|"* ]]
}

# ---------------------------------------------------------------------------
# Phase 3: Per-step rendering
# ---------------------------------------------------------------------------

# Truncate a field value using head/tail sandwich with traj stub.
truncate_field() {
    local value="$1" limit="$2" ref="$3" total_bytes="$4" step_id="$5" field_name="$6"
    local val_bytes
    val_bytes=$(printf '%s' "$value" | LC_ALL=C wc -c | tr -d ' ')

    if [[ "$val_bytes" -le "$limit" ]]; then
        printf '%s' "$value"
        return
    fi

    # When limit is 0 or very small, emit just the stub.
    if [[ "$limit" -le 1 ]]; then
        local stub_ref=""
        [[ -n "$ref" ]] && stub_ref=" full output at $ref —"
        printf '[... truncated: %s bytes total.%s\n read with: traj show %s %s --full, or traj search %s <pattern>]' \
            "$total_bytes" "$stub_ref" "$RUN_DIR" "$step_id" "$RUN_DIR"
        return
    fi

    local half=$(( limit / 2 ))
    [[ "$half" -lt 1 ]] && half=1
    local head_part tail_part
    head_part=$(printf '%s' "$value" | head -c "$half")
    tail_part=$(printf '%s' "$value" | tail -c "$half")

    local stub_ref=""
    [[ -n "$ref" ]] && stub_ref=" full output at $ref —"

    printf '%s' "$head_part"
    printf '\n[... truncated: %s bytes total.%s\n read with: traj show %s %s --full, or traj search %s <pattern>]\n' \
        "$total_bytes" "$stub_ref" "$RUN_DIR" "$step_id" "$RUN_DIR"
    printf '%s' "$tail_part"
}

# Render a single step row into text.
render_step() {
    local row="$1" prompt_limit="$2"
    local step_id
    step_id=$(printf '%s' "$row" | jq -r '.step_id')

    # Check if this is a prompt record (initial task).
    local prompt_val
    prompt_val=$(printf '%s' "$row" | jq -r '.prompt // empty')
    if [[ -n "$prompt_val" ]]; then
        local output="=== task ==="$'\n'"$prompt_val"$'\n\n'
        printf '%s' "$output"
        return
    fi

    local output=""

    output+="--- step $step_id"
    if field_enabled ts; then
        local ts
        ts=$(printf '%s' "$row" | jq -r '.ts // empty')
        [[ -n "$ts" ]] && output+=" (ts:$ts)"
    fi
    # Check for timed_out flag.
    local timed_out
    timed_out=$(printf '%s' "$row" | jq -r '.timed_out // empty')
    [[ "$timed_out" == "true" ]] && output+=" [TIMED OUT]"
    output+=$' ---\n'

    if field_enabled thought; then
        local thought
        thought=$(printf '%s' "$row" | jq -r '.thought // empty')
        if [[ -n "$thought" ]]; then
            output+="[thought]"$'\n'"$thought"$'\n\n'
        fi
    fi

    if field_enabled cmd; then
        local cmd
        cmd=$(printf '%s' "$row" | jq -r '.cmd // empty')
        if [[ -n "$cmd" ]]; then
            output+='```bash'$'\n'"$cmd"$'\n```\n\n'
        fi
    fi

    if field_enabled exit; then
        local exit_code
        exit_code=$(printf '%s' "$row" | jq -r '.exit // empty')
        if [[ -n "$exit_code" ]]; then
            output+="exit: $exit_code"$'\n'
        fi
    fi

    # Show feedback for timed-out steps (replaces stdout).
    if [[ "$timed_out" == "true" ]]; then
        local feedback
        feedback=$(printf '%s' "$row" | jq -r '.feedback // empty')
        if [[ -n "$feedback" ]]; then
            output+="[feedback]"$'\n'"$feedback"$'\n\n'
        fi
    fi

    if field_enabled stdout; then
        local stdout_val stdout_ref stdout_bytes stdout_trunc
        stdout_val=$(printf '%s' "$row" | jq -r '.stdout // empty')
        stdout_ref=$(printf '%s' "$row" | jq -r '.stdout_ref // empty')
        stdout_bytes=$(printf '%s' "$row" | jq -r '.stdout_bytes // empty')
        stdout_trunc=$(printf '%s' "$row" | jq -r '.stdout_truncated // empty')

        if [[ -n "$stdout_val" ]]; then
            local display_bytes
            display_bytes=$(printf '%s' "$stdout_val" | LC_ALL=C wc -c | tr -d ' ')
            [[ -n "$stdout_bytes" ]] && display_bytes="$stdout_bytes"

            local rendered
            rendered=$(truncate_field "$stdout_val" "$prompt_limit" "$stdout_ref" "$display_bytes" "$step_id" "stdout")
            output+="[stdout]"$'\n'"$rendered"$'\n\n'
        fi
    fi

    if field_enabled stderr; then
        local stderr_val stderr_ref stderr_bytes stderr_trunc
        stderr_val=$(printf '%s' "$row" | jq -r '.stderr // empty')
        stderr_ref=$(printf '%s' "$row" | jq -r '.stderr_ref // empty')
        stderr_bytes=$(printf '%s' "$row" | jq -r '.stderr_bytes // empty')
        stderr_trunc=$(printf '%s' "$row" | jq -r '.stderr_truncated // empty')

        if [[ -n "$stderr_val" ]]; then
            local display_bytes
            display_bytes=$(printf '%s' "$stderr_val" | LC_ALL=C wc -c | tr -d ' ')
            [[ -n "$stderr_bytes" ]] && display_bytes="$stderr_bytes"

            local rendered
            rendered=$(truncate_field "$stderr_val" "$prompt_limit" "$stderr_ref" "$display_bytes" "$step_id" "stderr")
            output+="[stderr]"$'\n'"$rendered"$'\n\n'
        fi
    fi

    # Show final answer if present.
    local final_val
    final_val=$(printf '%s' "$row" | jq -r '.final // empty')
    if [[ -n "$final_val" ]]; then
        output+="[final]"$'\n'"$final_val"$'\n\n'
    fi

    printf '%s' "$output"
}

# ---------------------------------------------------------------------------
# Phase 4: Assemble output with elision
# ---------------------------------------------------------------------------

assemble() {
    local prompt_limit="$1"
    local output=""
    local elided_count=0
    local elided_digests=()  # bash 3.2: no local -a needed

    for ((i=0; i<TOTAL; i++)); do
        if is_selected "$i"; then
            # Flush any pending elision marker.
            if [[ "$elided_count" -gt 0 ]]; then
                case "$CTX_ELISION_STYLE" in
                    none) ;;
                    count)
                        output+="[$elided_count steps elided]"$'\n\n'
                        ;;
                    digest)
                        for _d in "${elided_digests[@]}"; do
                            output+="$_d"$'\n'
                        done
                        output+=$'\n'
                        ;;
                esac
                elided_count=0
                elided_digests=()
            fi

            # Render the selected step.
            local rendered
            rendered=$(render_step "${ALL_ROWS[$i]}" "$prompt_limit")
            output+="$rendered"
        else
            # Step is elided.
            elided_count=$((elided_count + 1))
            if [[ "$CTX_ELISION_STYLE" == "digest" ]]; then
                local _row="${ALL_ROWS[$i]}"
                local _sid _cmd _exit _sbytes
                _sid=$(printf '%s' "$_row" | jq -r '.step_id // "?"')
                _cmd=$(printf '%s' "$_row" | jq -r '.cmd // ""' | head -c 80)
                _exit=$(printf '%s' "$_row" | jq -r '.exit // "?"')
                _sbytes=$(printf '%s' "$_row" | jq -r '.stdout_bytes // (.stdout | length) // 0')
                elided_digests+=("[step $_sid: $_cmd (exit $_exit, ${_sbytes}B)]")
            fi
        fi
    done

    # Flush trailing elision.
    if [[ "$elided_count" -gt 0 ]]; then
        case "$CTX_ELISION_STYLE" in
            none) ;;
            count)
                output+="[$elided_count steps elided]"$'\n\n'
                ;;
            digest)
                for _d in "${elided_digests[@]}"; do
                    output+="$_d"$'\n'
                done
                output+=$'\n'
                ;;
        esac
    fi

    printf '%s' "$output"
}

# ---------------------------------------------------------------------------
# Phase 5: Budget enforcement
# ---------------------------------------------------------------------------

enforce_budget() {
    local result
    result=$(assemble "$CTX_PROMPT_LIMIT")

    if [[ -z "$CTX_MAX_BYTES" ]]; then
        printf '%s' "$result"
        return
    fi

    local result_bytes
    result_bytes=$(printf '%s' "$result" | LC_ALL=C wc -c | tr -d ' ')

    if [[ "$result_bytes" -le "$CTX_MAX_BYTES" ]]; then
        printf '%s' "$result"
        return
    fi

    # Binary search for the right prompt_limit to fit the budget.
    local lo=0 hi="$CTX_PROMPT_LIMIT"
    local best_result="$result"
    local best_bytes="$result_bytes"

    while [[ "$lo" -le "$hi" ]]; do
        local mid=$(( (lo + hi) / 2 ))
        local try_result
        try_result=$(assemble "$mid")
        local try_bytes
        try_bytes=$(printf '%s' "$try_result" | LC_ALL=C wc -c | tr -d ' ')

        if [[ "$try_bytes" -le "$CTX_MAX_BYTES" ]]; then
            best_result="$try_result"
            best_bytes="$try_bytes"
            lo=$((mid + 1))
        else
            hi=$((mid - 1))
        fi
    done

    # If even with prompt_limit=0 we exceed budget, emit what we have and warn.
    if [[ "$best_bytes" -gt "$CTX_MAX_BYTES" ]]; then
        printf '%s' "$best_result" | head -c "$CTX_MAX_BYTES"
        printf '[budget exceeded: trajectory too dense]' >&2
    else
        printf '%s' "$best_result"
    fi
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

if [[ "$TOTAL" -eq 0 ]]; then
    # Empty trajectory, nothing to render.
    exit 0
fi

enforce_budget
