#!/usr/bin/env bash
set -euo pipefail

# context — Policy layer that reads a trajectory and outputs a JSON messages
# array with role assignment driven by flags.  The caller passes the output
# to `llm -M` and provides its own system prompt via `llm -s`.

# ---------------------------------------------------------------------------
# Defaults
# ---------------------------------------------------------------------------

CTX_HEAD="${CTX_HEAD:-1}"
CTX_TAIL="${CTX_TAIL:-50}"
CTX_PROMPT_LIMIT="${SHELLM_STDOUT_PROMPT_LIMIT:-2048}"
CTX_MAX_BYTES=""
CTX_ELISION_STYLE="count"  # none|count
CTX_PINS=()

CTX_ASSISTANT_TYPES=""
CTX_USER_TYPES=""
CTX_EXCLUDE_TYPES=""
CTX_BRANCH="root"

die() { printf 'context: error: %s\n' "$*" >&2; exit 1; }
usage() {
    cat <<'EOF'
Usage: context <traj_dir> [options]

Reads a trajectory branch and outputs a JSON messages array to stdout.

Role assignment:
  --assistant-types LIST  Step types that become {"role":"assistant"}.
  --user-types LIST       Step types that become {"role":"user"}.
  --exclude-types LIST    Step types to drop entirely.
  Unrecognized types (not in any list) default to "user" role.

Step selection:
  --head N              Keep first N steps. Default: 1.
  --tail N              Keep last N steps. Default: 50.
  --pin <step_id>       Always include this step. Repeatable.

Per-step content:
  --prompt-limit BYTES  Per-step field truncation for large values. Default: 2048.

Elision:
  --elision-style S     none|count. Default: count.

Budget:
  --max-bytes BYTES     Cap total output. Default: unset.

Branch:
  --branch NAME         Which branch to render. Default: root.

Output:
  A JSON array: [{"role":"user","content":"..."},{"role":"assistant","content":"..."},...]
  Consecutive messages with the same role are merged (Anthropic API requires alternation).

EOF
    exit "${1:-0}"
}

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------

TRAJ_DIR=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --head)             CTX_HEAD="${2:?--head requires N}"; shift 2 ;;
        --tail)             CTX_TAIL="${2:?--tail requires N}"; shift 2 ;;
        --pin)              CTX_PINS+=("${2:?--pin requires step_id}"); shift 2 ;;
        --prompt-limit)     CTX_PROMPT_LIMIT="${2:?--prompt-limit requires BYTES}"; shift 2 ;;
        --elision-style)    CTX_ELISION_STYLE="${2:?--elision-style requires a value}"; shift 2 ;;
        --max-bytes)        CTX_MAX_BYTES="${2:?--max-bytes requires BYTES}"; shift 2 ;;
        --assistant-types)  CTX_ASSISTANT_TYPES="${2:?--assistant-types requires LIST}"; shift 2 ;;
        --user-types)       CTX_USER_TYPES="${2:?--user-types requires LIST}"; shift 2 ;;
        --exclude-types)    CTX_EXCLUDE_TYPES="${2:?--exclude-types requires LIST}"; shift 2 ;;
        --branch)           CTX_BRANCH="${2:?--branch requires NAME}"; shift 2 ;;
        -h|--help)          usage 0 ;;
        -*)                 die "unknown option: $1" ;;
        *)
            if [[ -z "$TRAJ_DIR" ]]; then
                TRAJ_DIR="$1"
            else
                die "unexpected argument: $1"
            fi
            shift
            ;;
    esac
done

[[ -n "$TRAJ_DIR" ]] || die "traj_dir is required"

# ---------------------------------------------------------------------------
# Resolve trajectory file (with backward compat)
# ---------------------------------------------------------------------------

TRAJ_FILE="$TRAJ_DIR/${CTX_BRANCH}.jsonl"
if [[ "$CTX_BRANCH" == "root" && ! -f "$TRAJ_FILE" ]]; then
    if [[ -f "$TRAJ_DIR/trajectory.jsonl" ]]; then
        TRAJ_FILE="$TRAJ_DIR/trajectory.jsonl"
    fi
fi

[[ -f "$TRAJ_FILE" ]] || die "trajectory not found: $TRAJ_FILE"

# ---------------------------------------------------------------------------
# Build type sets for role assignment (pipe-delimited for bash 3.2 compat)
# ---------------------------------------------------------------------------

_ASSISTANT_SET=""
if [[ -n "$CTX_ASSISTANT_TYPES" ]]; then
    IFS=',' read -ra _types <<< "$CTX_ASSISTANT_TYPES"
    for _t in "${_types[@]}"; do
        _ASSISTANT_SET="${_ASSISTANT_SET}|${_t}|"
    done
fi

_USER_SET=""
if [[ -n "$CTX_USER_TYPES" ]]; then
    IFS=',' read -ra _types <<< "$CTX_USER_TYPES"
    for _t in "${_types[@]}"; do
        _USER_SET="${_USER_SET}|${_t}|"
    done
fi

_EXCLUDE_SET=""
if [[ -n "$CTX_EXCLUDE_TYPES" ]]; then
    IFS=',' read -ra _types <<< "$CTX_EXCLUDE_TYPES"
    for _t in "${_types[@]}"; do
        _EXCLUDE_SET="${_EXCLUDE_SET}|${_t}|"
    done
fi

is_assistant_type() { [[ "$_ASSISTANT_SET" == *"|$1|"* ]]; }
is_user_type()      { [[ "$_USER_SET" == *"|$1|"* ]]; }
is_excluded_type()  { [[ -n "$_EXCLUDE_SET" ]] && [[ "$_EXCLUDE_SET" == *"|$1|"* ]]; }

# Determine role for a step type.
role_for_type() {
    local step_type="$1"
    if is_excluded_type "$step_type"; then
        echo "exclude"
    elif is_assistant_type "$step_type"; then
        echo "assistant"
    elif is_user_type "$step_type"; then
        echo "user"
    else
        # Default: user for unrecognized types
        echo "user"
    fi
}

# Build pin set as delimited string for lookup.
_PIN_SET=""
for _p in "${CTX_PINS[@]+"${CTX_PINS[@]}"}"; do
    _PIN_SET="${_PIN_SET}|${_p}|"
done

pin_match() {
    [[ "$_PIN_SET" == *"|$1|"* ]]
}

# ---------------------------------------------------------------------------
# Metadata keys to skip when rendering step content
# ---------------------------------------------------------------------------

_META_KEYS="|step_id|ts|type|"
is_meta_key() {
    local key="$1"
    # Skip step_id, ts, type, and any key ending in _ref, _bytes, _truncated
    [[ "$_META_KEYS" == *"|$key|"* ]] && return 0
    case "$key" in
        *_ref|*_bytes|*_truncated) return 0 ;;
    esac
    return 1
}

# ---------------------------------------------------------------------------
# Phase 1: Load trajectory rows
# ---------------------------------------------------------------------------

ALL_ROWS=()
ALL_IDS=()
ALL_TYPES=()
while IFS= read -r line; do
    local_id=$(printf '%s' "$line" | jq -r '.step_id // empty' 2>/dev/null)
    [[ -n "$local_id" ]] || continue
    local_type=$(printf '%s' "$line" | jq -r '.type // empty' 2>/dev/null)
    ALL_ROWS+=("$line")
    ALL_IDS+=("$local_id")
    ALL_TYPES+=("$local_type")
done < "$TRAJ_FILE"

TOTAL=${#ALL_ROWS[@]}

# ---------------------------------------------------------------------------
# Phase 2: Step selection (head / tail / pins)
# ---------------------------------------------------------------------------

_SELECTED=""

# Head: first N steps.
for ((i=0; i<TOTAL && i<CTX_HEAD; i++)); do
    _SELECTED="${_SELECTED}|${i}|"
done

# Tail: last N steps.
tail_start=$((TOTAL - CTX_TAIL))
[[ "$tail_start" -lt 0 ]] && tail_start=0
for ((i=tail_start; i<TOTAL; i++)); do
    _SELECTED="${_SELECTED}|${i}|"
done

# Pins: find by step_id.
for ((i=0; i<TOTAL; i++)); do
    if pin_match "${ALL_IDS[$i]}"; then
        _SELECTED="${_SELECTED}|${i}|"
    fi
done

is_selected() {
    [[ "$_SELECTED" == *"|$1|"* ]]
}

# ---------------------------------------------------------------------------
# Phase 3: Truncation helper
# ---------------------------------------------------------------------------

truncate_field() {
    local value="$1" limit="$2" step_id="$3"
    local val_bytes
    val_bytes=$(printf '%s' "$value" | LC_ALL=C wc -c | tr -d ' ')

    if [[ "$val_bytes" -le "$limit" ]]; then
        printf '%s' "$value"
        return
    fi

    if [[ "$limit" -le 1 ]]; then
        printf '[... truncated: %s bytes total. read with: traj show %s %s --full]' \
            "$val_bytes" "$TRAJ_DIR" "$step_id"
        return
    fi

    local half=$(( limit / 2 ))
    [[ "$half" -lt 1 ]] && half=1
    local head_part tail_part
    head_part=$(printf '%s' "$value" | head -c "$half")
    tail_part=$(printf '%s' "$value" | tail -c "$half")

    printf '%s' "$head_part"
    printf '\n[... truncated: %s bytes total. read with: traj show %s %s --full]\n' \
        "$val_bytes" "$TRAJ_DIR" "$step_id"
    printf '%s' "$tail_part"
}

# ---------------------------------------------------------------------------
# Phase 4: Render steps into role+content pairs, with elision
# ---------------------------------------------------------------------------

# Render a single step row into text content for a message.
render_step() {
    local row="$1" prompt_limit="$2"
    local step_id
    step_id=$(printf '%s' "$row" | jq -r '.step_id')

    # Get all non-metadata keys and their values.
    local keys
    keys=$(printf '%s' "$row" | jq -r 'keys[]')

    # Count non-metadata keys to decide on wrapper format.
    local content_keys=()
    local k
    while IFS= read -r k; do
        [[ -z "$k" ]] && continue
        is_meta_key "$k" && continue
        content_keys+=("$k")
    done <<< "$keys"

    local output=""
    local num_content=${#content_keys[@]}

    for k in "${content_keys[@]}"; do
        local val
        val=$(printf '%s' "$row" | jq -r ".${k} // empty")
        [[ -n "$val" ]] || continue

        # Truncate large values.
        local val_bytes
        val_bytes=$(printf '%s' "$val" | LC_ALL=C wc -c | tr -d ' ')
        if [[ "$val_bytes" -gt "$prompt_limit" ]]; then
            val=$(truncate_field "$val" "$prompt_limit" "$step_id")
        fi

        if [[ "$num_content" -eq 1 ]]; then
            # Single content key: just the value.
            output="$val"
        elif [[ "$k" == "cmd" ]]; then
            # Render commands as fenced code blocks so the model sees
            # its own output format in history, not [cmd] markers.
            output+='```bash'$'\n'"${val}"$'\n```\n\n'
        elif [[ "$k" == "thought" ]]; then
            output+="${val}"$'\n\n'
        else
            # Generic fallback for other multi-key steps.
            output+="[${k}]"$'\n'"${val}"$'\n\n'
        fi
    done

    printf '%s' "$output"
}

# Build the messages array.
# Returns a list of (role, content) pairs as a JSON array.
build_messages() {
    local prompt_limit="$1"

    # Accumulate messages as a JSON array.
    local messages="[]"
    local elided_count=0

    for ((i=0; i<TOTAL; i++)); do
        local step_type="${ALL_TYPES[$i]}"
        local role
        role=$(role_for_type "$step_type")

        # Skip excluded types entirely.
        [[ "$role" == "exclude" ]] && continue

        if is_selected "$i"; then
            # Flush elision marker.
            if [[ "$elided_count" -gt 0 && "$CTX_ELISION_STYLE" != "none" ]]; then
                local elision_text="[$elided_count steps elided]"
                # Elision markers become user messages.
                messages=$(printf '%s' "$messages" | jq --arg c "$elision_text" '. + [{"role":"user","content":$c}]')
                elided_count=0
            fi

            # Render the step.
            local content
            content=$(render_step "${ALL_ROWS[$i]}" "$prompt_limit")
            [[ -n "$content" ]] || continue

            messages=$(printf '%s' "$messages" | jq --arg r "$role" --arg c "$content" '. + [{"role":$r,"content":$c}]')
        else
            elided_count=$((elided_count + 1))
        fi
    done

    # Flush trailing elision.
    if [[ "$elided_count" -gt 0 && "$CTX_ELISION_STYLE" != "none" ]]; then
        local elision_text="[$elided_count steps elided]"
        messages=$(printf '%s' "$messages" | jq --arg c "$elision_text" '. + [{"role":"user","content":$c}]')
    fi

    printf '%s' "$messages"
}

# ---------------------------------------------------------------------------
# Phase 5: Consecutive-role merging
# ---------------------------------------------------------------------------

# Anthropic API requires alternating user/assistant roles.
# Merge consecutive messages with the same role.
merge_consecutive_roles() {
    local messages="$1"
    printf '%s' "$messages" | jq '
        reduce .[] as $msg ([];
            if (length > 0) and (.[-1].role == $msg.role) then
                .[-1].content += ("\n---\n" + $msg.content)
            else
                . + [$msg]
            end
        )
    '
}

# ---------------------------------------------------------------------------
# Phase 6: Budget enforcement
# ---------------------------------------------------------------------------

enforce_budget() {
    local result
    result=$(build_messages "$CTX_PROMPT_LIMIT")
    result=$(merge_consecutive_roles "$result")

    if [[ -z "$CTX_MAX_BYTES" ]]; then
        printf '%s' "$result"
        return
    fi

    local result_bytes
    result_bytes=$(printf '%s' "$result" | LC_ALL=C wc -c | tr -d ' ')

    if [[ "$result_bytes" -le "$CTX_MAX_BYTES" ]]; then
        printf '%s' "$result"
        return
    fi

    # Binary search for the right prompt_limit to fit the budget.
    local lo=0 hi="$CTX_PROMPT_LIMIT"
    local best_result="$result"
    local best_bytes="$result_bytes"

    while [[ "$lo" -le "$hi" ]]; do
        local mid=$(( (lo + hi) / 2 ))
        local try_result
        try_result=$(build_messages "$mid")
        try_result=$(merge_consecutive_roles "$try_result")
        local try_bytes
        try_bytes=$(printf '%s' "$try_result" | LC_ALL=C wc -c | tr -d ' ')

        if [[ "$try_bytes" -le "$CTX_MAX_BYTES" ]]; then
            best_result="$try_result"
            best_bytes="$try_bytes"
            lo=$((mid + 1))
        else
            hi=$((mid - 1))
        fi
    done

    if [[ "$best_bytes" -gt "$CTX_MAX_BYTES" ]]; then
        printf '%s' "$best_result" | head -c "$CTX_MAX_BYTES"
        printf '[budget exceeded: trajectory too dense]' >&2
    else
        printf '%s' "$best_result"
    fi
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

if [[ "$TOTAL" -eq 0 ]]; then
    # Empty trajectory: output empty messages array.
    printf '[]\n'
    exit 0
fi

enforce_budget
