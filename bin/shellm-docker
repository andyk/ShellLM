#!/usr/bin/env bash
set -euo pipefail

usage() {
    cat <<'EOF'
Usage:
  shellm-docker run IMAGE -- CMD [ARG...]
  shellm-docker build DIR TAG
  shellm-docker ps
  shellm-docker logs CONTAINER
  shellm-docker rm CONTAINER

shellm-docker talks to the host-side shellm Docker broker. It is intentionally
not a pass-through wrapper for the docker CLI.
EOF
}

docker_usage() {
    cat <<'EOF'
Usage:
  docker info
  docker --version
  docker version [ARG...]
  docker compose --version
  docker compose SUBCOMMAND [ARG...]
  docker ps
  docker logs CONTAINER
  docker rm CONTAINER

This is shellm's constrained Docker facade. It supports the Docker commands
needed by Harbor and forwards them to the host-side shellm Docker broker.
EOF
}

die() { echo "shellm-docker: error: $*" >&2; exit 1; }

make_args_json() {
    if [[ "$#" -eq 0 ]]; then
        printf '[]\n'
    else
        printf '%s\0' "$@" | jq -Rs 'split("\u0000")[:-1]'
    fi
}

make_env_json() {
    env -0 | jq -Rs '
        split("\u0000")[:-1]
        | map(index("=") as $i | select($i != null) | {key: .[0:$i], value: .[$i+1:]})
        | from_entries
    '
}

make_request_json() {
    local op="$1"
    local include_env="$2"
    shift 2
    local args_json env_json
    args_json=$(make_args_json "$@")
    if [[ "$include_env" -eq 1 ]]; then
        env_json=$(make_env_json)
    else
        env_json='{}'
    fi
    jq -n \
        --arg op "$op" \
        --arg cwd "$PWD" \
        --arg workdir "${SHELLM_WORKDIR:-$PWD}" \
        --argjson args "$args_json" \
        --argjson env "$env_json" \
        '{op:$op,args:$args,cwd:$cwd,workdir:$workdir,env:$env}'
}

send_request() {
    local op="$1"
    local include_env="$2"
    shift 2
    local request response transport
    request=$(make_request_json "$op" "$include_env" "$@")
    transport="${SHELLM_DOCKER_TRANSPORT:-${SHELLM_DOCKER_BROKER_TRANSPORT:-filesystem}}"
    case "$transport" in
        socket) response=$(send_socket "$request") ;;
        filesystem) response=$(send_filesystem "$request") ;;
        *) die "unsupported broker transport: $transport" ;;
    esac

    print_response "$response"
}

send_socket() {
    local request="$1"
    local broker_dir="${SHELLM_DOCKER_BROKER:-}"
    [[ -n "$broker_dir" ]] || die "SHELLM_DOCKER_BROKER is not set"
    local socket="$broker_dir/broker.sock"
    [[ -S "$socket" ]] || die "broker socket not found: $socket"
    command -v socat >/dev/null 2>&1 || die "socket transport requires socat in the shellm container"
    printf '%s' "$request" | socat - "UNIX-CONNECT:$socket"
}

send_filesystem() {
    local request="$1"
    local broker_dir="${SHELLM_DOCKER_BROKER:-}"
    [[ -n "$broker_dir" ]] || die "SHELLM_DOCKER_BROKER is not set"
    local req_dir="$broker_dir/requests"
    local res_dir="$broker_dir/responses"
    mkdir -p "$req_dir" "$res_dir"

    local rand
    rand=$(head -c4 /dev/urandom | od -An -tx1 | tr -d ' \n')
    local id
    id="$(date +%s)-$$-$rand"
    local tmp="$req_dir/$id.tmp"
    local req="$req_dir/$id.json"
    local res="$res_dir/$id.json"

    printf '%s' "$request" > "$tmp"
    mv "$tmp" "$req"

    # Harbor tasks can legitimately run for several hours; let Harbor's own
    # per-task timeout be the primary bound instead of cutting Docker off first.
    local timeout="${SHELLM_DOCKER_REQUEST_TIMEOUT:-14400}"
    local waited=0
    while [[ ! -f "$res" ]]; do
        if [[ "$waited" -ge "$timeout" ]]; then
            rm -f "$req" "$tmp"
            die "timed out waiting for broker response after ${timeout}s"
        fi
        sleep 1
        waited=$((waited + 1))
    done

    cat "$res"
    rm -f "$res"
}

print_response() {
    local response="$1"
    if ! printf '%s' "$response" | jq -e '.exit_code' >/dev/null 2>&1; then
        printf '%s\n' "$response" >&2
        die "invalid broker response"
    fi

    printf '%s' "$response" | jq -rj '.stdout // ""'
    printf '%s' "$response" | jq -rj '.stderr // ""' >&2

    local exit_code
    exit_code=$(printf '%s' "$response" | jq -r '.exit_code')
    exit "$exit_code"
}

main() {
    [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && { usage; exit 0; }
    [[ $# -ge 1 ]] || { usage >&2; exit 1; }
    [[ "${SHELLM_DOCKER_ACCESS:-}" == "broker" ]] || die "shellm-docker is only available when SHELLM_DOCKER_ACCESS=broker"

    local op="$1"
    shift
    case "$op" in
        run|build|ps|logs|rm) ;;
        *) die "unsupported operation: $op" ;;
    esac

    send_request "$op" 0 "$@"
}

docker_main() {
    [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && { docker_usage; exit 0; }
    [[ "${1:-}" == "-v" || "${1:-}" == "--version" ]] && { send_request version 0 "$@"; exit 0; }
    [[ $# -ge 1 ]] || { docker_usage >&2; exit 1; }
    [[ "${SHELLM_DOCKER_ACCESS:-}" == "broker" ]] || die "docker facade is only available when SHELLM_DOCKER_ACCESS=broker"

    local op="$1"
    shift
    case "$op" in
        info)
            send_request info 0 "$@"
            ;;
        version)
            send_request version 0 "$@"
            ;;
        compose)
            [[ "$#" -ge 1 ]] || die "docker compose requires a subcommand"
            case "${1:-}" in
                -v|--version) send_request compose 0 version ;;
                *) send_request compose 1 "$@" ;;
            esac
            ;;
        ps|logs|rm)
            send_request "$op" 0 "$@"
            ;;
        *)
            die "unsupported docker facade operation: $op"
            ;;
    esac
}

case "$(basename "$0")" in
    docker) docker_main "$@" ;;
    *) main "$@" ;;
esac
