#!/usr/bin/env bash
set -euo pipefail

# traj — Trajectory DAG substrate.
# General-purpose step log with UUID step IDs, a required `type` field,
# and branch support.  No filtering policy; that lives in `context`.
#
# Directory layout:
#   <traj_dir>/
#     root.jsonl              # main branch
#     <branch-name>.jsonl     # child branches
#     blobs/                  # spilled large fields

# ---------------------------------------------------------------------------
# Defaults & constants
# ---------------------------------------------------------------------------

STDOUT_INLINE_LIMIT="${SHELLM_STDOUT_INLINE_LIMIT:-4096}"

die() { printf 'traj: error: %s\n' "$*" >&2; exit 1; }
usage() {
    cat <<'EOF'
Usage: traj <command> [args]

Commands:
  append <traj_dir> [--branch NAME]
                            Read a step JSON from stdin (must have a `type`
                            field), assign UUID step_id, spill large fields
                            to blobs, append to the branch file.
                            Default branch: root.

  show <traj_dir> <step_id> [--branch NAME] [--full] [--field F]
                            Pretty-print a single step.

  tail <traj_dir> [--branch NAME] [-n N] [-f]
                            Like tail but for a branch's JSONL file.

  search <traj_dir> <pattern> [--branch NAME] [--field F] [-i] [-C N] [-E]
                            Search step fields. Default field: all.

  branches <traj_dir>       List all branches (one name per line).

EOF
    exit "${1:-0}"
}

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

# Generate a UUID step id.
gen_step_id() {
    if command -v uuidgen >/dev/null 2>&1; then
        uuidgen | tr '[:upper:]' '[:lower:]'
    elif [[ -f /proc/sys/kernel/random/uuid ]]; then
        cat /proc/sys/kernel/random/uuid
    else
        # Fallback: construct from /dev/urandom
        local hex
        hex=$(head -c16 /dev/urandom | od -An -tx1 | tr -d ' \n')
        printf '%s-%s-%s-%s-%s\n' \
            "${hex:0:8}" "${hex:8:4}" "${hex:12:4}" "${hex:16:4}" "${hex:20:12}"
    fi
}

# Determine the next blob_id for a step by counting existing blobs.
next_blob_id() {
    local blob_dir="$1" step_id="$2"
    local count=0
    if [[ -d "$blob_dir" ]]; then
        count=$(find "$blob_dir" -maxdepth 1 -name "${step_id}-*" \( -name '*.stdout' -o -name '*.stderr' \) 2>/dev/null | wc -l | tr -d ' ')
    fi
    printf '%06x' "$count"
}

# Byte length of a string (LC_ALL=C to count bytes, not chars).
byte_len() {
    printf '%s' "$1" | LC_ALL=C wc -c | tr -d ' '
}

# Resolve the JSONL file for a branch.
# Handles backward compatibility: if root is requested and root.jsonl
# doesn't exist but trajectory.jsonl does, use trajectory.jsonl.
resolve_branch_file() {
    local traj_dir="$1" branch="$2"
    local branch_file="$traj_dir/${branch}.jsonl"

    if [[ "$branch" == "root" && ! -f "$branch_file" ]]; then
        # Backward compat: old single-file format
        if [[ -f "$traj_dir/trajectory.jsonl" ]]; then
            printf '%s\n' "$traj_dir/trajectory.jsonl"
            return
        fi
    fi
    printf '%s\n' "$branch_file"
}

# Like resolve_branch_file but requires the file to exist.
require_branch_file() {
    local traj_dir="$1" branch="$2" cmd="$3"
    local branch_file
    branch_file=$(resolve_branch_file "$traj_dir" "$branch")
    [[ -f "$branch_file" ]] || die "$cmd: branch file not found: $branch_file"
    printf '%s\n' "$branch_file"
}

# ---------------------------------------------------------------------------
# append
# ---------------------------------------------------------------------------

cmd_append() {
    local traj_dir="" branch="root"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --branch) branch="${2:?--branch requires NAME}"; shift 2 ;;
            -*)       die "append: unknown option: $1" ;;
            *)
                if [[ -z "$traj_dir" ]]; then
                    traj_dir="$1"
                else
                    die "append: unexpected argument: $1"
                fi
                shift
                ;;
        esac
    done
    [[ -n "$traj_dir" ]] || die "append requires <traj_dir>"

    local branch_file
    branch_file=$(resolve_branch_file "$traj_dir" "$branch")
    local blob_dir="$traj_dir/blobs"

    # Read the step record from stdin.
    local record
    record=$(cat)
    [[ -n "$record" ]] || die "append: empty stdin"

    # Validate it's JSON.
    printf '%s' "$record" | jq empty 2>/dev/null || die "append: invalid JSON on stdin"

    # Validate type field is present.
    local step_type
    step_type=$(printf '%s' "$record" | jq -r '.type // empty')
    [[ -n "$step_type" ]] || die "append: step record must have a 'type' field"

    # Assign step id.
    local step_id
    step_id=$(gen_step_id)

    # Add step_id and ts (if not already present).
    record=$(printf '%s' "$record" | jq --arg id "$step_id" '. + {step_id: $id} | if .ts == null then . + {ts: (now | floor)} else . end')

    # Process stdout: spill if over limit.
    local stdout_val
    stdout_val=$(printf '%s' "$record" | jq -r '.stdout // empty')
    local stdout_bytes
    stdout_bytes=$(byte_len "$stdout_val")

    if [[ "$stdout_bytes" -gt "$STDOUT_INLINE_LIMIT" ]] && [[ -n "$stdout_val" ]]; then
        mkdir -p "$blob_dir"
        local blob_id
        blob_id=$(next_blob_id "$blob_dir" "$step_id")
        local blob_file="$blob_dir/${step_id}-${blob_id}.stdout"
        local blob_ref="blobs/${step_id}-${blob_id}.stdout"

        # Write blob first (atomic: write to temp then rename).
        local tmp_blob
        tmp_blob=$(mktemp "$blob_dir/.tmp.XXXXXX")
        printf '%s' "$stdout_val" > "$tmp_blob"
        sync "$tmp_blob" 2>/dev/null || true
        mv "$tmp_blob" "$blob_file"

        # Truncate inline to first INLINE_LIMIT bytes.
        local inline_val
        inline_val=$(printf '%s' "$stdout_val" | head -c "$STDOUT_INLINE_LIMIT")

        record=$(printf '%s' "$record" | jq \
            --arg stdout "$inline_val" \
            --arg ref "$blob_ref" \
            --argjson bytes "$stdout_bytes" \
            '. + {stdout: $stdout, stdout_ref: $ref, stdout_bytes: $bytes, stdout_truncated: true}')
    fi

    # Process stderr: spill if over limit.
    local stderr_val
    stderr_val=$(printf '%s' "$record" | jq -r '.stderr // empty')
    local stderr_bytes
    stderr_bytes=$(byte_len "$stderr_val")

    if [[ "$stderr_bytes" -gt "$STDOUT_INLINE_LIMIT" ]] && [[ -n "$stderr_val" ]]; then
        mkdir -p "$blob_dir"
        local blob_id
        blob_id=$(next_blob_id "$blob_dir" "$step_id")
        local blob_file="$blob_dir/${step_id}-${blob_id}.stderr"
        local blob_ref="blobs/${step_id}-${blob_id}.stderr"

        local tmp_blob
        tmp_blob=$(mktemp "$blob_dir/.tmp.XXXXXX")
        printf '%s' "$stderr_val" > "$tmp_blob"
        sync "$tmp_blob" 2>/dev/null || true
        mv "$tmp_blob" "$blob_file"

        local inline_val
        inline_val=$(printf '%s' "$stderr_val" | head -c "$STDOUT_INLINE_LIMIT")

        record=$(printf '%s' "$record" | jq \
            --arg stderr "$inline_val" \
            --arg ref "$blob_ref" \
            --argjson bytes "$stderr_bytes" \
            '. + {stderr: $stderr, stderr_ref: $ref, stderr_bytes: $bytes, stderr_truncated: true}')
    fi

    # Append row to branch file (compact, one line).
    mkdir -p "$traj_dir"
    local compact
    compact=$(printf '%s' "$record" | jq -c .)
    printf '%s\n' "$compact" >> "$branch_file"

    # Print the assigned step_id so the caller knows it.
    printf '%s\n' "$step_id"
}

# ---------------------------------------------------------------------------
# show
# ---------------------------------------------------------------------------

cmd_show() {
    local traj_dir="" step="" full=0 field="" branch="root"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --full)    full=1; shift ;;
            --field)   field="${2:?--field requires a value}"; shift 2 ;;
            --branch)  branch="${2:?--branch requires NAME}"; shift 2 ;;
            -*)        die "show: unknown option: $1" ;;
            *)
                if [[ -z "$traj_dir" ]]; then
                    traj_dir="$1"
                elif [[ -z "$step" ]]; then
                    step="$1"
                else
                    die "show: unexpected argument: $1"
                fi
                shift
                ;;
        esac
    done
    [[ -n "$traj_dir" ]] || die "show requires <traj_dir>"
    [[ -n "$step" ]] || die "show requires <step_id>"

    local branch_file
    branch_file=$(require_branch_file "$traj_dir" "$branch" "show")

    local row
    row=$(jq -c --arg id "$step" 'select(.step_id == $id)' "$branch_file" | head -1)
    [[ -n "$row" ]] || die "show: step $step not found"

    local blob_dir="$traj_dir/blobs"

    # If --full, replace truncated stdout/stderr with blob contents.
    if [[ "$full" -eq 1 ]]; then
        local stdout_ref
        stdout_ref=$(printf '%s' "$row" | jq -r '.stdout_ref // empty')
        if [[ -n "$stdout_ref" ]]; then
            local blob_path="$traj_dir/$stdout_ref"
            if [[ -f "$blob_path" ]]; then
                local full_stdout
                full_stdout=$(cat "$blob_path")
                row=$(printf '%s' "$row" | jq --arg v "$full_stdout" '.stdout = $v | del(.stdout_truncated)')
            fi
        fi
        local stderr_ref
        stderr_ref=$(printf '%s' "$row" | jq -r '.stderr_ref // empty')
        if [[ -n "$stderr_ref" ]]; then
            local blob_path="$traj_dir/$stderr_ref"
            if [[ -f "$blob_path" ]]; then
                local full_stderr
                full_stderr=$(cat "$blob_path")
                row=$(printf '%s' "$row" | jq --arg v "$full_stderr" '.stderr = $v | del(.stderr_truncated)')
            fi
        fi
    fi

    # If --field, emit just that field's raw bytes.
    if [[ -n "$field" ]]; then
        printf '%s' "$row" | jq -r ".${field} // empty"
        return
    fi

    # Pretty-print the step.
    printf '%s' "$row" | jq .
}

# ---------------------------------------------------------------------------
# tail
# ---------------------------------------------------------------------------

cmd_tail() {
    local traj_dir="" n=10 follow=0 branch="root"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -n)       n="${2:?-n requires a number}"; shift 2 ;;
            -f)       follow=1; shift ;;
            --branch) branch="${2:?--branch requires NAME}"; shift 2 ;;
            -*)       die "tail: unknown option: $1" ;;
            *)
                if [[ -z "$traj_dir" ]]; then
                    traj_dir="$1"
                else
                    die "tail: unexpected argument: $1"
                fi
                shift
                ;;
        esac
    done
    [[ -n "$traj_dir" ]] || die "tail requires <traj_dir>"

    local branch_file
    branch_file=$(require_branch_file "$traj_dir" "$branch" "tail")

    if [[ "$follow" -eq 1 ]]; then
        tail -n "$n" -f "$branch_file" | while IFS= read -r line; do
            printf '%s\n' "$line" | jq -c . 2>/dev/null || printf '%s\n' "$line"
        done
    else
        tail -n "$n" "$branch_file"
    fi
}

# ---------------------------------------------------------------------------
# search
# ---------------------------------------------------------------------------

cmd_search() {
    local traj_dir="" pattern="" field="all" case_flag="" context_lines=0 use_regex=0 branch="root"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --field)  field="${2:?--field requires a value}"; shift 2 ;;
            --branch) branch="${2:?--branch requires NAME}"; shift 2 ;;
            -i)       case_flag="-i"; shift ;;
            -C)       context_lines="${2:?-C requires a number}"; shift 2 ;;
            -E)       use_regex=1; shift ;;
            -*)       die "search: unknown option: $1" ;;
            *)
                if [[ -z "$traj_dir" ]]; then
                    traj_dir="$1"
                elif [[ -z "$pattern" ]]; then
                    pattern="$1"
                else
                    die "search: unexpected argument: $1"
                fi
                shift
                ;;
        esac
    done
    [[ -n "$traj_dir" ]] || die "search requires <traj_dir>"
    [[ -n "$pattern" ]] || die "search requires <pattern>"

    local branch_file
    branch_file=$(require_branch_file "$traj_dir" "$branch" "search")

    # Search all non-metadata fields by default, or specific field.
    local fields_to_search
    case "$field" in
        all) fields_to_search="content thought cmd stdout stderr" ;;
        *)   fields_to_search="$field" ;;
    esac

    local grep_mode="-F"  # literal by default
    [[ "$use_regex" -eq 1 ]] && grep_mode="-E"

    local -a grep_args=($grep_mode)
    [[ -n "$case_flag" ]] && grep_args+=($case_flag)
    [[ "$context_lines" -gt 0 ]] && grep_args+=(-C "$context_lines")
    grep_args+=(-n)  # line numbers

    local blob_dir="$traj_dir/blobs"

    # Iterate over each row in the trajectory.
    while IFS= read -r row; do
        local step_id
        step_id=$(printf '%s' "$row" | jq -r '.step_id // empty')
        [[ -n "$step_id" ]] || continue

        for f in $fields_to_search; do
            local content=""

            # For stdout/stderr, check if there's a blob and use that for full search.
            local ref_key="${f}_ref"
            local ref_val
            ref_val=$(printf '%s' "$row" | jq -r ".${ref_key} // empty" 2>/dev/null)

            if [[ -n "$ref_val" ]] && [[ -f "$traj_dir/$ref_val" ]]; then
                content=$(cat "$traj_dir/$ref_val")
            else
                content=$(printf '%s' "$row" | jq -r ".${f} // empty")
            fi

            [[ -n "$content" ]] || continue

            # Search the content.
            local matches
            matches=$(printf '%s\n' "$content" | grep "${grep_args[@]}" -- "$pattern" 2>/dev/null || true)
            [[ -n "$matches" ]] || continue

            # Format output: <step>:<field>:<line_no>: <line>
            while IFS= read -r match_line; do
                printf '%s:%s:%s\n' "$step_id" "$f" "$match_line"
            done <<< "$matches"
        done
    done < "$branch_file"
}

# ---------------------------------------------------------------------------
# branches
# ---------------------------------------------------------------------------

cmd_branches() {
    local traj_dir="${1:?branches requires <traj_dir>}"

    [[ -d "$traj_dir" ]] || die "branches: directory not found: $traj_dir"

    # List all .jsonl files, mapping trajectory.jsonl → root for compat.
    # Use a delimited string to deduplicate (bash 3.2 compat).
    local _seen="" f name
    for f in "$traj_dir"/*.jsonl; do
        [[ -f "$f" ]] || continue
        name=$(basename "$f" .jsonl)
        [[ "$name" == "trajectory" ]] && name="root"
        case "$_seen" in
            *"|${name}|"*) continue ;;
        esac
        _seen="${_seen}|${name}|"
        printf '%s\n' "$name"
    done
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------

[[ $# -gt 0 ]] || usage 1
cmd="$1"; shift
case "$cmd" in
    append)   cmd_append "$@" ;;
    show)     cmd_show "$@" ;;
    tail)     cmd_tail "$@" ;;
    search)   cmd_search "$@" ;;
    branches) cmd_branches "$@" ;;
    help|-h|--help) usage 0 ;;
    *) die "unknown command: $cmd" ;;
esac
